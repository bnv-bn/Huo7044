local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

-- Variables
local TargetPos = nil
local Flying = false
local FlySpeed = 50
local Sliding = false
local SlideSpeed = 50
local BringingAll = false

-- === สร้าง UI หลัก (Draggable & Closable) ===
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 250, 0, 450)
MainFrame.Position = UDim2.new(0.5, -125, 0.5, -225)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.Active = true
Instance.new("UICorner", MainFrame)

-- ปุ่มลาก (+)
local DragBtn = Instance.new("TextLabel", MainFrame)
DragBtn.Size = UDim2.new(0, 30, 0, 30)
DragBtn.Text = "+"
DragBtn.TextColor3 = Color3.new(1,1,1)
DragBtn.BackgroundTransparency = 1
DragBtn.TextSize = 25

-- ระบบลาก (Draggable)
local dragStart, startPos, dragging
DragBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true dragStart = input.Position startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

-- ส่วน List ปุ่ม
local Scroll = Instance.new("ScrollingFrame", MainFrame)
Scroll.Size = UDim2.new(1, 0, 1, -40)
Scroll.Position = UDim2.new(0, 0, 0, 40)
Scroll.BackgroundTransparency = 1
Scroll.CanvasSize = UDim2.new(0, 0, 2, 0)
local UIList = Instance.new("UIListLayout", Scroll)
UIList.Padding = UDim.new(0, 5)
UIList.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- === ฟังก์ชันสร้างปุ่มพร้อมปุ่มแยกด้านขวา ===
local function CreateComplexButton(txt, color, callback, subCallback)
    local Container = Instance.new("Frame", Scroll)
    Container.Size = UDim2.new(0.95, 0, 0, 40)
    Container.BackgroundTransparency = 1

    local MainBtn = Instance.new("TextButton", Container)
    MainBtn.Size = UDim2.new(0.75, 0, 1, 0)
    MainBtn.Text = txt
    MainBtn.BackgroundColor3 = color
    MainBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", MainBtn)
    MainBtn.MouseButton1Click:Connect(callback)

    local SubBtn = Instance.new("TextButton", Container)
    SubBtn.Size = UDim2.new(0.2, 0, 1, 0)
    SubBtn.Position = UDim2.new(0.8, 0, 0, 0)
    SubBtn.Text = "⚙️"
    SubBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    SubBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", SubBtn)
    SubBtn.MouseButton1Click:Connect(subCallback)
end

-- 1. Smooth Spiderman (Lerp TP)
CreateComplexButton("SMOOTH SPIDER", Color3.fromRGB(150, 0, 0), function()
    if TargetPos then
        local char = LP.Character
        task.spawn(function()
            for i = 0, 1, 0.05 do -- ความละเอียดของการขยับ
                if not char or not char:FindFirstChild("HumanoidRootPart") then break end
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame:Lerp(TargetPos, i)
                task.wait(0.02)
            end
        end)
    end
end, function() print("ตั้งค่า Spider") end)

-- 2. Fly Mode พร้อมปรับความเร็ว
CreateComplexButton("FLY MODE", Color3.fromRGB(0, 100, 200), function()
    Flying = not Flying
    if Flying then
        local bv = Instance.new("BodyVelocity", LP.Character.HumanoidRootPart)
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        task.spawn(function()
            while Flying do
                bv.Velocity = LP.Character.Humanoid:GetMoveDirection() * FlySpeed
                task.wait()
            end
            bv:Destroy()
        end)
    end
end, function()
    FlySpeed = (FlySpeed == 50) and 150 or 50
    print("Fly Speed: "..FlySpeed)
end)

-- 3. Bring All Players (Loop)
CreateComplexButton("BRING ALL", Color3.fromRGB(100, 0, 150), function()
    BringingAll = not BringingAll
    task.spawn(function()
        while BringingAll do
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                end
            end
            task.wait(0.5)
        end
    end)
end, function() BringingAll = false print("ยกเลิกดึงคน") end)

-- 4. Slide Mode (Auto Run สำหรับ Evade/ทุกแมพ)
CreateComplexButton("SLIDE MODE", Color3.fromRGB(0, 150, 100), function()
    Sliding = not Sliding
    task.spawn(function()
        while Sliding do
            local char = LP.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:Move(Vector3.new(0, 0, -1), true) -- บังคับเดินไปข้างหน้า
                char.Humanoid.WalkSpeed = SlideSpeed
            end
            task.wait()
        end
        LP.Character.Humanoid.WalkSpeed = 16
    end)
end, function()
    SlideSpeed = (SlideSpeed == 50) and 100 or 50
    print("Slide Speed: "..SlideSpeed)
end)

-- 5. Wall TP (Forward)
CreateComplexButton("WALL TP", Color3.fromRGB(80, 80, 80), function()
    LP.Character.HumanoidRootPart.CFrame *= CFrame.new(0,0,-12)
end, function() print("Set Distance") end)

-- ปุ่มพื้นฐาน
CreateComplexButton("SET POS", Color3.fromRGB(0, 120, 0), function() TargetPos = LP.Character.HumanoidRootPart.CFrame end, function() TargetPos = nil end)
