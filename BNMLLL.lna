-- ⚔️ 2. ระบบต่อสู้ & แดช (Combat)
-- ==========================================
CombatTab:CreateToggle({Name = "Silent Aim (ล็อคเป้า)", Callback = function(V) SilentAimEnabled = V end})
CombatTab:CreateSlider({Name = "พุ่งบนพื้น (Ground Dash)", Range = {50, 500}, Increment = 5, CurrentValue = 80, Callback = function(V) GroundDashSpeed = V end})
CombatTab:CreateButton({Name = "รับคทาวาร์ป (Teleport Tool)", Callback = function() 
    local tool = Instance.new("Tool")
    tool.Name = "นางฟ้าวาร์ป🪽"
    tool.RequiresHandle = false
    tool.Activated:Connect(function()
        local pos = Player:GetMouse().Hit.Position
        Root.CFrame = CFrame.new(pos + Vector3.new(0,3,0))
    end)
    tool.Parent = Player.Backpack
end})

-- ==========================================
-- 🌍 3. ระบบเสกแมพ (Map Spawner - 10 แมพครบ)
-- ==========================================
local function spawnMap(assetId, height)
    if currentMap then currentMap:Destroy() end
    local success, model = pcall(function() return game:GetObjects("rbxassetid://" .. assetId)[1] end)
    if success and model then
        model.Parent = workspace; currentMap = model
        model:PivotTo(model:GetPivot() + Vector3.new(0, height, 0))
        task.wait(0.5); Root.CFrame = model:GetPivot() * CFrame.new(0, 15, 0)
        Rayfield:Notify({Title="Map Spawner", Content="เสกสำเร็จ!", Duration=3})
    end
end

MapTab:CreateSection("--- แผนที่และบ้านทั้งหมด ---")
