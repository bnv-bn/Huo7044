-- ⏱️ 6. ระบบมินิเกม & จับเวลา (Game)
-- ==========================================
local TimerLabel = GameTab:CreateLabel("เวลาคงเหลือ: 10:00")
GameTab:CreateButton({Name = "เริ่ม/หยุด จับเวลา", Callback = function() TimerRunning = not TimerRunning end})
GameTab:CreateButton({Name = "เปิดเกมเป่ายิ้งฉุบ", Callback = function() rpsFolder.Visible = true end})

-- [ ระบบ RPS ]
local MiniGui = Instance.new("ScreenGui", game.CoreGui)
local rpsFolder = Instance.new("Frame", MiniGui)
rpsFolder.Size = UDim2.new(0,360,0,240); rpsFolder.Position = UDim2.new(0.5,0,0.5,0); rpsFolder.AnchorPoint = Vector2.new(0.5,0.5); rpsFolder.BackgroundColor3 = Color3.fromRGB(20,20,20); rpsFolder.Visible = false; Instance.new("UICorner", rpsFolder)
local rpsStroke = Instance.new("UIStroke", rpsFolder); rpsStroke.Thickness = 3
local rpsText = Instance.new("TextLabel", rpsFolder)
rpsText.Size = UDim2.new(1,-20,0,50); rpsText.Position = UDim2.new(0,10,1,-60); rpsText.BackgroundTransparency = 1; rpsText.TextScaled = true; rpsText.TextColor3 = Color3.new(1,1,1); rpsText.Text = "เป่ายิ้งฉุบ!"

local function playRPS(p)
    local choices = {["✂️"] = "📃", ["📃"] = "🧱", ["🧱"] = "✂️"} local em = {"✂️","📃","🧱"}
    for i=1,12 do rpsText.Text = "ยิ้งงง ฉุบ! "..em[math.random(3)] task.wait(0.06) end
    local b = em[math.random(3)] rpsText.Text = "คุณ: "..p.." VS บอท: "..b
    task.wait(1.5)
    if choices[p] == b then rpsText.Text = "ชนะ!" elseif p == b then rpsText.Text = "เสมอ!" else rpsText.Text = "แพ้! ปิดโปร!!" task.wait(1) Rayfield:Destroy() MiniGui:Destroy() end
end
local g = Instance.new("UIGridLayout", rpsFolder); g.CellSize = UDim2.new(0,90,0,90); g.HorizontalAlignment = "Center"
local function cB(t) local b = Instance.new("TextButton", rpsFolder); b.Text = t; b.TextScaled = true; b.MouseButton1Click:Connect(function() playRPS(t) end) end
cB("🧱"); cB("📃"); cB("✂️"); g.Parent = rpsFolder

-- ==========================================
-- 🌈 7. Mini UI (ปุ่มบวกสายรุ้ง)
-- ==========================================
local PlusBtn = Instance.new("TextButton", MiniGui)
PlusBtn.Size = UDim2.new(0, 60, 0, 60); PlusBtn.Position = UDim2.new(0.9, -10, 0.5, -30); PlusBtn.Text = "+"; PlusBtn.BackgroundColor3 = Color3.new(1,0,0); Instance.new("UICorner", PlusBtn).CornerRadius = UDim.new(1,0)
local MiniFrame = Instance.new("Frame", MiniGui); MiniFrame.Size = UDim2.new(0, 150, 0, 420); MiniFrame.Position = UDim2.new(0.9, -170, 0.5, -210); MiniFrame.Visible = false; MiniFrame.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", MiniFrame)
local L = Instance.new("UIListLayout", MiniFrame); L.Padding = UDim.new(0,5); L.HorizontalAlignment = "Center"
local function QB(t, f) local b = Instance.new("TextButton", MiniFrame); b.Size = UDim2.new(0, 130, 0, 35); b.Text = t; b.BackgroundColor3 = Color3.fromRGB(50,50,50); b.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", b); b.MouseButton1Click:Connect(f) end
QB("เมนูหลัก", function() Rayfield:Toggle() end)
QB("☀️ เช้า", function() game.Lighting.ClockTime = 12 end)
QB("🌑 มืด", function() game.Lighting.ClockTime = 0 end)
QB("พุ่ง (Dash)", function() if Root then Root.Velocity = Root.CFrame.LookVector * GroundDashSpeed end end)
QB("บิน: ON/OFF", function() Flying = not Flying end)
PlusBtn.MouseButton1Click:Connect(function() MiniFrame.Visible = not MiniFrame.Visible end)

-- [[ 🔄 Core Loops ]]
game:GetService("RunService").RenderStepped:Connect(function()
    if Root and Humanoid then
        if Flying then Root.Velocity = workspace.CurrentCamera.CFrame.LookVector * FlySpeed end
        if SpiderManEnabled then
            local r = workspace:Raycast(Root.Position, Root.CFrame.LookVector * 2.5)
            if r then Root.Velocity = Vector3.new(Root.Velocity.X, 45, Root.Velocity.Z) end
        end
        if not Flying then Humanoid.WalkSpeed = WalkSpeedValue end
    end
end)
spawn(function()
    while true do task.wait(1)
        if TimerRunning and TimeLeft > 0 then TimeLeft = TimeLeft - 1
            TimerLabel:Set("เวลาคงเหลือ: "..string.format("%02d:%02d", math.floor(TimeLeft/60), TimeLeft%60))
        end
    end
end)
spawn(function()
    local h = 0 while true do local c = Color3.fromHSV(h, 0.8, 1) PlusBtn.BackgroundColor3 = c; rpsStroke.Color = c; h = h + 0.01; task.wait(0.05) end
end)

Rayfield:Notify({Title = "นางฟ้า Hub V.27", Content = "รวมทุกระบบและไอเทมครบถ้วน!", Duration = 5})
