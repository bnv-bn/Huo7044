-- 📍 5. ระบบวาร์ปหาคน (Teleport)
-- ==========================================
local TargetPlayer = ""
TP_Tab:CreateInput({Name = "ชื่อผู้เล่น", PlaceholderText = "พิมพ์ชื่อ...", Callback = function(T) TargetPlayer = T end})
TP_Tab:CreateButton({Name = "วาร์ปไปหาคนนี้", Callback = function()
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():find(TargetPlayer:lower()) and v.Character then
            Root.CFrame = v.Character.HumanoidRootPart.CFrame
        end
    end
end})

