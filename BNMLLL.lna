local MapTab = Window:CreateTab("เสกแมพมัลติเวิร์ส", 4483362458)
local VisualTab = Window:CreateTab("แสงสี/กาลเวลา", 4483362458)
local TP_Tab = Window:CreateTab("วาร์ปหาคน", 4483362458)
local GameTab = Window:CreateTab("มินิเกม/จับเวลา", 4483362458)
