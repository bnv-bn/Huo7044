local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "นางฟ้า hub🪽 V.27 [COMPLETE]",
   LoadingTitle = "กำลังรวบรวมมัลติเวิร์สและคลังแสง...",
   LoadingSubtitle = "เพิ่มระบบรับไอเทม (Tool Master) เรียบร้อย",
   ConfigurationSaving = { Enabled = false }
})

-- [[ 💾 คลังตัวแปรทั้งหมด (ห้ามลบ) ]]
local Player = game.Players.LocalPlayer
local Character, Humanoid, Root
local WalkSpeedValue, JumpPowerValue = 16, 50
local GravityValue = 196.2
local FlySpeed, ClickSpeed = 50, 0.1
local GroundDashSpeed, AirDashSpeed = 80, 120
local Flying, SpiderManEnabled, InfJump, AutoClickEnabled = false, false, false, false
local FullBrightEnabled, AntiAFKEnabled, SilentAimEnabled = false, false, false
local XrayEnabled, HidePlayersEnabled = false, false
local TimeLeft, TimerRunning = 600, false
local currentMap = nil

local function UpdateCharacter()
    Character = Player.Character or Player.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    Root = Character:WaitForChild("HumanoidRootPart")
    Humanoid.UseJumpPower = true 
end
UpdateCharacter()
Player.CharacterAdded:Connect(function() task.wait(0.7) UpdateCharacter() end)

-- [[ 📂 TABS จัดหมวดหมู่ ]]
local MainTab = Window:CreateTab("เคลื่อนที่/บิน", 4483362458)
local CombatTab = Window:CreateTab("ต่อสู้/แดช", 4483362458)
