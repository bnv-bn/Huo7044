-- ==========================================
-- 🛠️ แท็บระบบรับไอเทม (Tool Master)
-- ==========================================
local function GetTool(assetId, toolName)
    local success, model = pcall(function() return game:GetObjects("rbxassetid://" .. assetId)[1] end)
    if success and model then
        model.Parent = Player.Backpack
        Rayfield:Notify({Title="Tool Master", Content="ได้รับ " .. toolName .. " แล้ว!", Duration=2})
    else
        Rayfield:Notify({Title="Error", Content="ไอเทมนี้อาจถูกลบหรือโหลดไม่ได้ในแมพนี้", Duration=2})
    end
end

ToolTab:CreateSection("--- อาวุธยอดนิยม ---")
ToolTab:CreateButton({Name = "⚔️ ดาบแสง (Linked Sword)", Callback = function() GetTool(125345, "ดาบในตำนาน") end})
ToolTab:CreateButton({Name = "🔫 ปืนเลเซอร์ (Hyperlaser)", Callback = function() GetTool(130113146, "ปืนเลเซอร์") end})
ToolTab:CreateButton({Name = "🔨 ค้อนยักษ์ (Gravity Hammer)", Callback = function() GetTool(33866828, "ค้อนแรงโน้มถ่วง") end})

ToolTab:CreateSection("--- ของกิน & ของฮา ---")
